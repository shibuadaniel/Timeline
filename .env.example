# Notion integration (Internal Integration): https://www.notion.so/my-integrations
NOTION_API_KEY=secret_...

# Sandbox database ID from the Notion URL (32 hex chars, with or without dashes).
NOTION_DATABASE_ID=350cb257e13c81ceaa4cdb0ad2bf0645

# Optional pilot window (defaults match Project Brief)
# PILOT_SEQUENCE_MIN=100
# PILOT_SEQUENCE_MAX=120

# API port when running `npm run dev:server` (optional). Vite’s `/api` proxy uses the same value from .env.
# Use this if 3001 is already in use (EADDRINUSE).
# PORT=3002
